{:pa.logging/timbre       {}

 :pa.observability/portal {:enabled? #boolean #or [#env PORTAL_ENABLED false]
                           :launcher #or [#env PORTAL_LAUNCHER "vs-code"]}

 :storage/fs              {}
 :storage/identity        {:fs #ig/ref :storage/fs}
 :storage/events          {:fs #ig/ref :storage/fs}
 :storage/history         {:fs #ig/ref :storage/fs}
 :memory/store            {:fs #ig/ref :storage/fs}
 :db/sqlite               {:fs #ig/ref :storage/fs}
 :memory/indexer          {:db #ig/ref :db/sqlite :fs #ig/ref :storage/fs}
 :llm/provider            {:provider  #keyword #or [#env LLM_PROVIDER "openai"]
                           :openai    {:api-key  #env OPENAI_API_KEY
                                       :base-url #or [#env OPENAI_BASE_URL "https://api.openai.com/v1"]
                                       :model    #or [#env OPENAI_MODEL "gpt-5"]}
                           :anthropic {:api-key  #env ANTHROPIC_API_KEY
                                       :base-url #or [#env ANTHROPIC_BASE_URL "https://api.anthropic.com/v1"]
                                       :model    #or [#env ANTHROPIC_MODEL "claude-sonnet-4-6"]}}
 :tool.fs/policy          {:fs #ig/ref :storage/fs}
 :ui/deltas               {}

 :pa.runtime/dispatcher   {:config   {:env :production}
                           :events   #ig/ref :storage/events
                           :identity #ig/ref :storage/identity
                           :history  #ig/ref :storage/history
                           :memory   #ig/ref :memory/store
                           :indexer  #ig/ref :memory/indexer
                           :llm      #ig/ref :llm/provider
                           :policy   #ig/ref :tool.fs/policy
                           :deltas   #ig/ref :ui/deltas}

 :pa/scheduler            {:fs         #ig/ref :storage/fs
                           :dispatcher #ig/ref :pa.runtime/dispatcher}

 :pa.ui/terminal          {:dispatcher #ig/ref :pa.runtime/dispatcher
                           :deltas     #ig/ref :ui/deltas}}
